# fud-arc bot — copy to .env (gitignored). NEVER commit real values.
BOT_TOKEN=
ARC_OPERATOR_KEY=
ARC_RPC=https://rpc.testnet.arc.network
FUDARCMARKET_ADDRESS=0x57352a7983E57De691fcEa5d7544CF6a398c0bf1
ARC_USDC_ADDRESS=0x3600000000000000000000000000000000000000
FRONTEND_URL=https://fud-arc-hackaton.vercel.app
# GenLayer is the primary resolver; Pyth remains the fallback.
GENLAYER_PRIVATE_KEY=
ARC_GENLAYER_NETWORK=studionet
GENLAYER_TIMEOUT_MS=75000
# PORT is injected by Railway
# Persist bot-opened market metadata and linked wallets across restarts.
# On Railway, mount a volume and set DATA_DIR to its mount path.
DATA_DIR=/data
