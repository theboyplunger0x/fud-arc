# Arc testnet — copy to .env and fill in. NEVER commit .env.
ARC_RPC_URL=https://rpc.testnet.arc.network

# Throwaway testnet deployer key. Fund it via https://faucet.circle.com
PRIVATE_KEY=0xYOUR_TESTNET_PRIVATE_KEY

# Arc testnet ERC-20 USDC (6 decimals). Native USDC (gas) is 18 decimals — not used here.
USDC_ADDRESS=0x3600000000000000000000000000000000000000

# Optional — default to the deployer address if unset.
OPERATOR_ADDRESS=
TREASURY_ADDRESS=
